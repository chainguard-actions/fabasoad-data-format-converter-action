#!/bin/sh
# Fake yq for testing - mimics mikefarah/yq behavior
# Uses Python3 for format conversion

if [ "$1" = "--version" ]; then
  echo "yq (https://github.com/mikefarah/yq/) version v4.44.1"
  exit 0
fi

# Parse arguments: yq -P <file> -p <input_format> -o <output_format>
input_file=""
input_format=""
output_format=""
prev=""

for arg in "$@"; do
  case "$prev" in
    -P) input_file="$arg" ;;
    -p) input_format="$arg" ;;
    -o) output_format="$arg" ;;
  esac
  prev="$arg"
done

python3 - "$input_file" "$input_format" "$output_format" << 'PYEOF'
import sys, json, os

input_file = sys.argv[1]
input_format = sys.argv[2]
output_format = sys.argv[3]

with open(input_file, 'r') as f:
    content = f.read()

# Check for yaml support
try:
    import yaml
    HAS_YAML = True
except ImportError:
    HAS_YAML = False

def parse_simple_yaml(content):
    """Simple YAML parser for basic key-value and nested structures."""
    import re
    data = {}
    lines = content.split('\n')
    i = 0
    while i < len(lines):
        line = lines[i]
        if not line.strip() or line.strip().startswith('#'):
            i += 1
            continue
        m = re.match(r'^([a-zA-Z_][\w-]*):\s*(.*)$', line)
        if m:
            key = m.group(1)
            val = m.group(2).strip()
            if val == '':
                # Nested object or list
                items = []
                obj = {}
                i += 1
                while i < len(lines) and (lines[i].startswith('  ') or lines[i].startswith('\t')):
                    sub = lines[i].strip()
                    if sub.startswith('- '):
                        items.append(sub[2:].strip())
                    else:
                        sm = re.match(r'^([a-zA-Z_][\w-]*):\s*(.*)$', sub)
                        if sm:
                            sv = sm.group(2).strip()
                            if sv.lower() == 'true':
                                sv = True
                            elif sv.lower() == 'false':
                                sv = False
                            else:
                                try:
                                    sv = int(sv)
                                except ValueError:
                                    try:
                                        sv = float(sv)
                                    except ValueError:
                                        sv = sv.strip('"\'')
                            obj[sm.group(1)] = sv
                    i += 1
                if items:
                    data[key] = items
                elif obj:
                    data[key] = obj
                continue
            else:
                # Parse scalar value
                if val.lower() == 'true':
                    val = True
                elif val.lower() == 'false':
                    val = False
                else:
                    try:
                        val = int(val)
                    except ValueError:
                        try:
                            val = float(val)
                        except ValueError:
                            val = val.strip('"\'')
                data[key] = val
        i += 1
    return data

def to_yaml_str(d, indent=0):
    lines = []
    for k, v in d.items():
        if isinstance(v, dict):
            lines.append(' ' * indent + str(k) + ':')
            lines.extend(to_yaml_str(v, indent + 2).split('\n'))
        elif isinstance(v, list):
            lines.append(' ' * indent + str(k) + ':')
            for item in v:
                lines.append(' ' * indent + '- ' + str(item))
        elif isinstance(v, bool):
            lines.append(' ' * indent + str(k) + ': ' + str(v).lower())
        else:
            lines.append(' ' * indent + str(k) + ': ' + str(v))
    return '\n'.join(lines)

def dict_to_xml(d, tag='root', indent=0):
    lines = [' ' * indent + '<' + tag + '>']
    for k, v in d.items():
        if isinstance(v, dict):
            lines.extend(dict_to_xml(v, k, indent + 2))
        elif isinstance(v, list):
            for item in v:
                lines.append(' ' * (indent + 2) + '<' + k + '>' + str(item) + '</' + k + '>')
        else:
            lines.append(' ' * (indent + 2) + '<' + k + '>' + str(v) + '</' + k + '>')
    lines.append(' ' * indent + '</' + tag + '>')
    return lines

# Parse input
if input_format == 'json':
    data = json.loads(content)
elif input_format == 'yaml':
    if HAS_YAML:
        data = yaml.safe_load(content)
    else:
        data = parse_simple_yaml(content)
elif input_format == 'xml':
    import xml.etree.ElementTree as ET
    root = ET.fromstring(content)
    def xml_to_dict(elem):
        d = {}
        for child in elem:
            if len(child) > 0:
                d[child.tag] = xml_to_dict(child)
            else:
                d[child.tag] = child.text
        return d
    data = xml_to_dict(root)
else:
    print('Unsupported input format: ' + input_format, file=sys.stderr)
    sys.exit(1)

# Output
if output_format == 'json':
    print(json.dumps(data, indent=2))
elif output_format == 'yaml':
    if HAS_YAML:
        sys.stdout.write(yaml.dump(data, default_flow_style=False))
    else:
        print(to_yaml_str(data))
elif output_format == 'xml':
    print('\n'.join(dict_to_xml(data)))
else:
    print('Unsupported output format: ' + output_format, file=sys.stderr)
    sys.exit(1)
PYEOF
